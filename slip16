Q.1) Using node js create a Recipe Book.

__(app.js)

const express = require("express");
const bodyParser = require("body-parser");

const app = express();

app.use(bodyParser.urlencoded({ extended: true }));

let recipes = [];

app.get("/", function(req, res) {
    let html = `
        <h2>Recipe Book</h2>
        <form method="post" action="/add">
            Recipe Name:<br>
            <input type="text" name="name"><br><br>
            Ingredients:<br>
            <input type="text" name="ingredients"><br><br>
            <input type="submit" value="Add Recipe">
        </form>
        <h3>Recipes:</h3>
        <ul>
    `;

    recipes.forEach(function(r) {
        html += `<li><b>${r.name}</b>: ${r.ingredients}</li>`;
    });

    html += "</ul>";
    res.send(html);
});

app.post("/add", function(req, res) {
    recipes.push({
        name: req.body.name,
        ingredients: req.body.ingredients
    });
    res.redirect("/");
});

app.listen(3000);

__Run
npm init -y
npm install express body-parser
node app.js

Open:
http://localhost:3000


Q.2) Create a js file named main.js for event-driven application. There should be a main 
loop that listens for events, and then triggers a call-back function when one of those events is detected.

__main.js


const EventEmitter = require("events");

const emitter = new EventEmitter();

emitter.on("start", function() {
    console.log("Start event triggered");
});

emitter.on("process", function(data) {
    console.log("Processing:", data);
});

emitter.on("end", function() {
    console.log("End event triggered");
});

console.log("Main loop listening for events...");

setTimeout(function() {
    emitter.emit("start");
}, 1000);

setTimeout(function() {
    emitter.emit("process", "Sample Data");
}, 2000);

setTimeout(function() {
    emitter.emit("end");
}, 3000);

__Run
node main.js

