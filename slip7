
Q.1) Create angular JS Application that show the current Date 
 and Time of the System (Use Interval Service)


<!DOCTYPE html>
<html ng-app="myApp">
<head>
    <title>Date & Time</title>
    <script src="https://ajax.googleapis.com/ajax/libs/angularjs/1.8.2/angular.min.js"></script>
</head>
<body ng-controller="myController">

<h2>Current Date and Time</h2>

<h3>{{currentDateTime | date:'yyyy-MM-dd HH:mm:ss'}}</h3>

<script>
var app = angular.module("myApp", []);

app.controller("myController", function($scope, $interval) {

    $scope.currentDateTime = new Date();

    $interval(function() {
        $scope.currentDateTime = new Date();
    }, 1000);

});
</script>

</body>
</html>


Q.2) Create a node js file named main.js for event-driven application.
 There should be a main loop that listens for events, and then triggers
 a callback function when one of those events is detected.


__main.js

const EventEmitter = require("events");

const eventEmitter = new EventEmitter();

eventEmitter.on("greet", function(name) {
    console.log("Hello " + name);
});

eventEmitter.on("bye", function() {
    console.log("Goodbye!");
});

console.log("Waiting for events...");

setTimeout(function() {
    eventEmitter.emit("greet", "Student");
}, 2000);

setTimeout(function() {
    eventEmitter.emit("bye");
}, 4000);

__Run
node main.js
