Q.2) Create an HTML form that contain the Student Registration details and write a 
JavaScript to validate Student first and last name as it should not contain other 
than alphabets and age should be between 18 to 50.


<!DOCTYPE html>
<html>
<head>
    <title>Student Registration</title>
    <script>
        function validateForm() {
            let fname = document.getElementById("fname").value.trim();
            let lname = document.getElementById("lname").value.trim();
            let age = parseInt(document.getElementById("age").value);

            let namePattern = /^[A-Za-z]+$/;

            if (!namePattern.test(fname)) {
                alert("First Name should contain only alphabets");
                return false;
            }

            if (!namePattern.test(lname)) {
                alert("Last Name should contain only alphabets");
                return false;
            }

            if (age < 18 || age > 50) {
                alert("Age must be between 18 and 50");
                return false;
            }

            alert("Registration Successful!");
            return true;
        }
    </script>
</head>
<body>

<h2>Student Registration Form</h2>

<form onsubmit="return validateForm()">

    First Name:<br>
    <input type="text" id="fname" required><br><br>

    Last Name:<br>
    <input type="text" id="lname" required><br><br>

    Age:<br>
    <input type="number" id="age" required><br><br>

    <input type="submit" value="Register">

</form>

</body>
</html>
